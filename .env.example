# Server（避開 3000/3001，本專案用 3003）
PORT=3003
NODE_ENV=development

# Database (PostgreSQL)
# 本地 Docker：docker compose up -d 後使用下方連線字串（見 docs/docker-database.md）
DATABASE_URL=postgresql://postgres:postgres@localhost:5435/construction_dashboard
# 正式環境（如 Railway）請改為實際 host / user / password / dbname
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# JWT（自訂隨機字串即可，不需從外部取得；正式環境請用強隨機值）
# 產生方式範例：openssl rand -base64 32
JWT_SECRET=your-jwt-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
# JWT 過期時間（可選，預設 7d；例：60s、24h、7d）
# JWT_EXPIRES_IN=7d

# CORS（前端 origin，多個用逗號分隔；本專案前端 dev port 5175）
# 僅本機：http://localhost:5175
# 手機／區網用本機 IP 開前端時，必須把該 origin 加進來，例如：
# CORS_ORIGIN=http://localhost:5175,http://192.168.0.33:5175
CORS_ORIGIN=http://localhost:5175,http://192.168.0.33:5175,http://192.168.0.215:5175

# 檔案儲存（開發用 local，產品可改 r2）
FILE_STORAGE_TYPE=local
FILE_STORAGE_LOCAL_PATH=./storage

# Cloudflare R2 (S3 相容，產品環境使用)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=
R2_PUBLIC_URL=

# 攝影機串流（Phase 3：go2rtc + mediamtx）
# 設備 RTSP 網址加密儲存用（32 字元 hex 或 44 字元 base64）；生產環境必設
# 產生方式：openssl rand -hex 16 或 openssl rand -base64 32
# ENCRYPTION_KEY=
# mediamtx REST API（僅 Backend 本機呼叫，預設 localhost:9997）
MEDIAMTX_API_URL=http://127.0.0.1:9997
# 對外 WebRTC 播放 base URL（前端播放用；生產請用 https）
MEDIAMTX_PUBLIC_HOST=http://localhost:8889
# RTMP 推流（go2rtc 用）：若用 Railway TCP Proxy，填 Proxy 的 host:port，例 yamabiko.proxy.rlwy.net:17161
# MEDIAMTX_RTMP_PUBLIC_HOST=yamabiko.proxy.rlwy.net:17161
# 未設 MEDIAMTX_RTMP_PUBLIC_HOST 時，由 MEDIAMTX_PUBLIC_HOST + 此 port 組 RTMP URL（預設 1935）
# MEDIAMTX_RTMP_PORT=1935
# 一鍵安裝包內腳本下載的 go2rtc 版本（預設 1.9.14）
# GO2RTC_VERSION=1.9.14
