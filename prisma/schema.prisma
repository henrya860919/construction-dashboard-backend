// Construction Dashboard - 多專案、人員；預留租戶
// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ---------- 租戶（多租戶時使用；單租戶可僅一筆或固定 id）----------
model Tenant {
  id               String    @id @default(cuid())
  name             String
  slug             String?
  logoStorageKey   String?   @map("logo_storage_key") // 公司 logo 儲存鍵
  status           String    @default("active") // active | suspended
  expiresAt        DateTime? @map("expires_at")
  userLimit        Int?      @map("user_limit")       // 人員上限（未來）
  fileSizeLimitMb  Int?      @map("file_size_limit_mb") // 單筆上傳 MB（未來）
  storageQuotaMb   Int?      @map("storage_quota_mb")   // 總儲存 MB（未來）
  /// 平台是否已於後台儲存過「模組開通」設定；false 時租戶端視為未開通（全模組不可用，不可新增專案／調整權限）
  moduleEntitlementsGranted Boolean @default(false) @map("module_entitlements_granted")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime? @map("deleted_at")
  deletedById      String?   @map("deleted_by_id")

  users         User[]
  projects      Project[]
  formTemplates FormTemplate[]
  selfInspectionTemplates SelfInspectionTemplate[]
  tenantPermissionTemplates TenantPermissionTemplate[]
  moduleDisables         TenantModuleDisable[]

  @@index([slug])
}

/// 平台關閉之模組：列于此表示該租戶不可使用該模組（含 tenant_admin）；未列則視為開通
model TenantModuleDisable {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  module    String   @map("module") // PermissionModuleId
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, module])
  @@index([tenantId])
  @@map("tenant_module_disables")
}

// ---------- 人員（使用者）----------
enum SystemRole {
  platform_admin  // 平台管理員（多租後台）
  tenant_admin    // 租戶／公司管理員（單租後台）
  project_user    // 專案層使用者
}

model User {
  id                String     @id @default(cuid())
  email             String
  passwordHash      String     @map("password_hash")
  name              String?
  avatarStorageKey  String?    @map("avatar_storage_key") // 個人頭貼（R2/儲存鍵）
  systemRole        SystemRole @default(project_user) @map("system_role")
  memberType        String     @default("internal") @map("member_type") // internal | external
  status            String     @default("active") @map("status") // active | suspended（停用後無法登入）
  tenantId          String?    @map("tenant_id")
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  deletedAt         DateTime?  @map("deleted_at")
  deletedById       String?    @map("deleted_by_id")

  tenant            Tenant?              @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  projectMembers    ProjectMember[]
  attachments       Attachment[]
  formTemplates     FormTemplate[]
  loginLogs         LoginLog[]
  auditLogs         AuditLog[]
  announcementReads AnnouncementRead[]
  photoFavorites    UserPhotoFavorite[]
  assignedIssueRisks ProjectIssueRisk[]
  defectExecutionRecords   DefectExecutionRecord[]
  repairExecutionRecords   RepairExecutionRecord[]
  selfInspectionRecordsFilled SelfInspectionRecord[]
  tenantPermissionTemplates   TenantPermissionTemplate[]
  projectMemberPermissions    ProjectMemberPermission[]
  pccesImportsCreated         PccesImport[]              @relation("PccesImportCreatedBy")
  pccesImportsApproved        PccesImport[]              @relation("PccesImportApprovedBy")
  pccesItemChangesCreated     PccesItemChange[]
  constructionDailyLogsCreated ConstructionDailyLog[]     @relation("ConstructionDailyLogCreatedBy")
  constructionValuationsCreated ConstructionValuation[]   @relation("ConstructionValuationCreatedBy")

  @@index([email])
}

// ---------- 登入紀錄（平台監控用）----------
model LoginLog {
  id            String    @id @default(cuid())
  userId        String?   @map("user_id")
  email         String    @map("email")
  success       Boolean   @map("success")
  ipAddress     String?   @map("ip_address")
  userAgent     String?   @map("user_agent")
  failureReason String?   @map("failure_reason")
  createdAt     DateTime  @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([email])
  @@index([success])
  @@map("login_logs")
}

// ---------- 稽核日誌（平台監控用）----------
model AuditLog {
  id           String    @id @default(cuid())
  userId       String?   @map("user_id")
  action       String    @map("action")
  resourceType String    @map("resource_type")
  resourceId   String?   @map("resource_id")
  tenantId     String?   @map("tenant_id")
  details      Json?     @map("details")
  ipAddress    String?   @map("ip_address")
  userAgent    String?   @map("user_agent")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt(sort: Desc)])
  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([tenantId])
  @@index([action])
  @@map("audit_logs")
}

// ---------- 平台公告（平台方發佈，可指定對象租戶或全平台）----------
model PlatformAnnouncement {
  id               String    @id @default(cuid())
  title            String    @map("title")
  body             String    @map("body")
  publishedAt      DateTime? @map("published_at")  // 發佈時間，null 表示未發佈
  expiresAt        DateTime? @map("expires_at")    // 下架時間，null 表示永不下架
  targetTenantIds  Json?     @map("target_tenant_ids")  // 指定租戶 ID 陣列；null 或 [] 表示全平台
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")
  deletedById      String?   @map("deleted_by_id")

  reads AnnouncementRead[]

  @@index([publishedAt, expiresAt])
  @@map("platform_announcements")
}

// ---------- 公告已讀（使用者關閉／已讀後紀錄，供「不再主動跳出」與統計）----------
model AnnouncementRead {
  id             String   @id @default(cuid())
  userId         String   @map("user_id")
  announcementId String   @map("announcement_id")
  readAt         DateTime @default(now()) @map("read_at")

  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  announcement PlatformAnnouncement @relation(fields: [announcementId], references: [id], onDelete: Cascade)

  @@unique([userId, announcementId])
  @@index([userId])
  @@index([announcementId])
  @@map("announcement_reads")
}

// ---------- 平台設定（key-value，維護模式、功能開關等）----------
model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique @map("key")
  value     String   @map("value")   // 字串或 JSON 字串
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("platform_settings")
}

// ---------- 表單樣板（相關表單：後台預設樣板 + 專案自訂樣板）----------
model FormTemplate {
  id            String    @id @default(cuid())
  tenantId      String?   @map("tenant_id")
  projectId     String?   @map("project_id")   // null = 後台預設樣板
  name          String    @map("name")         // 顯示名稱
  description   String?   @map("description")  // 描述
  storageKey    String    @map("storage_key")
  fileName      String    @map("file_name")
  fileSize      Int       @map("file_size")
  mimeType      String    @map("mime_type")
  fileHash      String?   @map("file_hash")
  uploadedById  String    @map("uploaded_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")

  tenant  Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy User  @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([projectId])
  @@map("form_templates")
}

// ---------- 自主檢查樣板（租戶後台：查驗表單結構；區塊供現場／專案自主檢查引用）----------
model SelfInspectionTemplate {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  name         String   @map("name")
  description  String?  @map("description")
  status       String   @default("active") @map("status") // active | archived
  /// 表單頂部基本資料：工程名稱、檢查時機選項、檢查結果圖例等（JSON；null 表示用後端預設）
  headerConfig Json?    @map("header_config")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  deletedById  String?   @map("deleted_by_id")

  tenant Tenant                        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  blocks SelfInspectionTemplateBlock[]
  records SelfInspectionRecord[]
  projectLinks ProjectSelfInspectionTemplateLink[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("self_inspection_templates")
}

/// 專案自選匯入之自主檢查樣板（未匯入者不出現在專案內；僅該樣板於專案內查驗次數為 0 時可移除匯入）
model ProjectSelfInspectionTemplateLink {
  id         String   @id @default(cuid())
  projectId  String   @map("project_id")
  templateId String   @map("template_id")
  createdAt  DateTime @default(now()) @map("created_at")
  deletedAt  DateTime? @map("deleted_at")
  deletedById String? @map("deleted_by_id")

  project  Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template SelfInspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([projectId, templateId])
  @@index([projectId])
  @@index([templateId])
  @@map("project_self_inspection_template_links")
}

/// 專案內自主查驗填寫紀錄（每次完整填寫一張表為一筆；統計次數即 COUNT）
model SelfInspectionRecord {
  id            String   @id @default(cuid())
  projectId     String   @map("project_id")
  templateId    String   @map("template_id")
  /// 抬頭與各列填寫：header、items[itemId]→actualText/resultOptionId 等（JSON）
  filledPayload Json     @map("filled_payload")
  /// 建立當下之樣板結構（template+blocks+items+headerConfig），供詳情顯示；租戶日後改樣板不影響本筆
  structureSnapshot Json? @map("structure_snapshot")
  filledById    String?  @map("filled_by_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")

  project  Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  template SelfInspectionTemplate @relation(fields: [templateId], references: [id], onDelete: Restrict)
  filledBy User?                  @relation(fields: [filledById], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([projectId, templateId])
  @@index([templateId])
  @@map("self_inspection_records")
}

model SelfInspectionTemplateBlock {
  id          String   @id @default(cuid())
  templateId  String   @map("template_id")
  title       String   @map("title")
  description String?  @map("description")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by_id")

  template SelfInspectionTemplate             @relation(fields: [templateId], references: [id], onDelete: Cascade)
  items    SelfInspectionTemplateBlockItem[]

  @@index([templateId])
  @@map("self_inspection_template_blocks")
}

/// 區塊內查驗列：分類（列合併）、檢查項目、規範標準；實際填寫欄位於現場執行時使用
model SelfInspectionTemplateBlockItem {
  id             String   @id @default(cuid())
  blockId        String   @map("block_id")
  categoryLabel  String   @map("category_label")
  itemName       String   @map("item_name")
  standardText   String   @map("standard_text")
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  deletedById    String?   @map("deleted_by_id")

  block SelfInspectionTemplateBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)

  @@index([blockId])
  @@map("self_inspection_template_block_items")
}

// ---------- 附件（檔案上傳 metadata，實體存儲存層）----------
model Attachment {
  id            String    @id @default(cuid())
  projectId     String    @map("project_id")
  tenantId      String?   @map("tenant_id")
  storageKey    String    @map("storage_key")
  fileName      String    @map("file_name")
  fileSize      Int       @map("file_size")
  mimeType      String    @map("mime_type")
  fileHash      String?   @map("file_hash")
  category      String?   @map("category")
  businessId    String?   @map("business_id")
  uploadedById  String    @map("uploaded_by_id")
  createdAt     DateTime  @default(now()) @map("created_at")
  deletedAt     DateTime? @map("deleted_at")
  deletedById   String?   @map("deleted_by_id")

  project          Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedBy       User                 @relation(fields: [uploadedById], references: [id], onDelete: Cascade)
  albumPhotos      AlbumPhoto[]
  userPhotoFavorites UserPhotoFavorite[]
  pccesImports     PccesImport[]

  @@map("attachments")
}

// ---------- 使用者照片最愛（個人，他人不可見）----------
model UserPhotoFavorite {
  userId       String   @map("user_id")
  attachmentId String   @map("attachment_id")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@id([userId, attachmentId])
  @@index([userId])
  @@index([attachmentId])
  @@map("user_photo_favorites")
}

// ---------- 專案 ----------
model Project {
  id          String   @id @default(cuid())
  name        String
  description String?
  code        String?  // 專案代碼
  status      String   @default("active") // active | archived
  tenantId    String?  @map("tenant_id")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 專案資訊（契約／工程基本資料）
  designUnit     String?   @map("design_unit")      // 設計單位
  supervisionUnit String?  @map("supervision_unit")  // 監造單位
  contractor     String?  @map("contractor")        // 施工廠商
  summary        String?  @map("summary")          // 工程概要
  benefits       String?  @map("benefits")          // 工程效益
  startDate           DateTime? @map("start_date")       // 開工日期
  plannedDurationDays Int?      @map("planned_duration_days") // 工期（天數）；預定完工 = 開工 + 工期
  plannedEndDate       DateTime? @map("planned_end_date")  // 預定完工日期（由開工+工期算出；保留供相容）
  revisedEndDate      DateTime? @map("revised_end_date")  // 預定竣工 = 開工+工期+調整工期（由 API 計算回傳）
  siteManager    String?  @map("site_manager")      // 工地負責人
  contactPhone   String?  @map("contact_phone")    // 聯絡電話
  projectStaff   String?  @map("project_staff")    // 專案工程人員
  deletedAt      DateTime? @map("deleted_at")
  deletedById    String?   @map("deleted_by_id")

  tenant              Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  projectMembers      ProjectMember[]
  scheduleAdjustments ProjectScheduleAdjustment[]
  attachments         Attachment[]
  formTemplates       FormTemplate[]
  photoAlbums         PhotoAlbum[]
  cameras             Camera[]
  alertRecords        AlertRecord[]
  wbsNodes            WbsNode[]
  issueRisks          ProjectIssueRisk[]
  resources           ProjectResource[]
  defectImprovements    DefectImprovement[]
  repairRequests                        RepairRequest[]
  selfInspectionRecords                 SelfInspectionRecord[]
  projectSelfInspectionTemplateLinks    ProjectSelfInspectionTemplateLink[]
  drawingNodes                          DrawingNode[]
  projectMemberPermissions              ProjectMemberPermission[]
  pccesImports                          PccesImport[]
  constructionDailyLogs                 ConstructionDailyLog[]
  constructionValuations                ConstructionValuation[]
}

// ---------- 圖說管理（專案內樹狀：folder=分類、leaf=圖說項；版本用 Attachment category=drawing_revision, businessId=leafId）----------
model DrawingNode {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  parentId  String?  @map("parent_id")
  /// folder | leaf（僅 leaf 可上傳檔案／版本鏈）
  kind      String   @map("kind")
  name      String   @map("name")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  deletedById String? @map("deleted_by_id")

  project  Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent   DrawingNode?    @relation("DrawingTree", fields: [parentId], references: [id], onDelete: Cascade)
  children DrawingNode[]   @relation("DrawingTree")

  @@index([projectId])
  @@index([parentId])
  @@map("drawing_nodes")
}

// ---------- WBS 工作分解結構（專案內樹狀，可拖移排序）----------
model WbsNode {
  id           String    @id @default(cuid())
  projectId    String    @map("project_id")
  parentId     String?   @map("parent_id")
  code         String    @map("code")       // 1, 1.1, 1.1.1（由系統依結構計算）
  name         String    @map("name")
  sortOrder    Int       @default(0) @map("sort_order")  // 同層排序
  startDate    DateTime? @map("start_date")  // 開始日期（甘特用）
  durationDays Int?     @map("duration_days") // 工期（天，含開始日）；結束 = 開始 + 工期 − 1
  variableCost Decimal? @map("variable_cost") @db.Decimal(14, 2) // 變動成本（由資源×用量計算後寫入）
  /// 專案根節點（名稱=專案名，僅 seed／遷移建立，不可刪改拖移）
  isProjectRoot Boolean  @default(false) @map("is_project_root")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  deletedById  String?   @map("deleted_by_id")

  project        Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent         WbsNode?          @relation("WbsTree", fields: [parentId], references: [id], onDelete: Cascade)
  children       WbsNode[]         @relation("WbsTree")
  issueRiskLinks ProjectIssueRiskWbsNode[]
  resourceLinks  WbsNodeResource[]

  @@index([projectId])
  @@index([parentId])
  @@map("wbs_nodes")
}

// WBS 節點 ↔ 專案資源 多對多（節點可選多個資源，含用量供變動成本計算）
model WbsNodeResource {
  wbsNodeId         String   @map("wbs_node_id")
  projectResourceId String   @map("project_resource_id")
  quantity          Decimal? @default(1) @map("quantity") @db.Decimal(14, 4) // 該節點使用該資源的用量（單位依 ProjectResource.unit）

  wbsNode   WbsNode         @relation(fields: [wbsNodeId], references: [id], onDelete: Cascade)
  resource  ProjectResource @relation(fields: [projectResourceId], references: [id], onDelete: Cascade)

  @@id([wbsNodeId, projectResourceId])
  @@index([projectResourceId])
  @@map("wbs_node_resources")
}

// ---------- 議題風險表（專案內：議題說明、負責人、緊急程度、影像任務 WBS、狀態）----------
model ProjectIssueRisk {
  id          String   @id @default(cuid())
  projectId   String   @map("project_id")
  description String   @map("description")   // 議題說明/現況說明
  assigneeId  String?  @map("assignee_id")   // 負責人（User）
  urgency     String   @default("medium") @map("urgency")  // low | medium | high | critical
  status      String   @default("open") @map("status")     // open | in_progress | resolved | closed
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by_id")

  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee  User?     @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  wbsLinks  ProjectIssueRiskWbsNode[]

  @@index([projectId])
  @@index([assigneeId])
  @@map("project_issue_risks")
}

model ProjectIssueRiskWbsNode {
  issueRiskId String @map("issue_risk_id")
  wbsNodeId   String @map("wbs_node_id")

  issueRisk ProjectIssueRisk @relation(fields: [issueRiskId], references: [id], onDelete: Cascade)
  wbsNode   WbsNode           @relation(fields: [wbsNodeId], references: [id], onDelete: Cascade)

  @@id([issueRiskId, wbsNodeId])
  @@index([wbsNodeId])
  @@map("project_issue_risk_wbs_nodes")
}

// ---------- 專案資源庫（人力、機具、材料）----------
model ProjectResource {
  id             String    @id @default(cuid())
  projectId      String    @map("project_id")
  type           String    @map("type")            // labor | equipment | material
  name           String    @map("name")
  unit           String    @map("unit")            // 單位（人天、台、噸等）
  unitCost       Float     @default(0) @map("unit_cost")   // 單位成本
  capacityType   String?   @map("capacity_type")   // 容量類型（選填）
  dailyCapacity  Float?    @map("daily_capacity")  // 每日容量（選填）
  vendor         String?   @map("vendor")          // 廠商（選填）
  description    String?   @map("description")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  deletedAt      DateTime? @map("deleted_at")
  deletedById    String?   @map("deleted_by_id")

  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  wbsNodeLinks WbsNodeResource[]

  @@index([projectId])
  @@index([projectId, type])
  @@map("project_resources")
}

// ---------- PCCES 匯入（施工日誌工項來源；每次上傳為一版）----------
model PccesImport {
  id             String    @id @default(cuid())
  projectId      String    @map("project_id")
  version        Int       // 專案內從 1 遞增
  /// 版本顯示名稱；第 1 版預設語意為「原契約」（可後改）。第 2 版起由使用者於上傳／Excel 確認時填寫。
  versionLabel   String?   @map("version_label") @db.VarChar(200)
  documentType   String?   @map("document_type") // budget | contract 等，來自 XML
  fileName       String    @map("file_name")
  attachmentId   String?   @map("attachment_id") // 原始 XML 歸檔（選用）
  itemCount      Int       @default(0) @map("item_count")
  generalCount   Int       @default(0) @map("general_count")
  /// 核定後施工日誌始得引用該版工項；null 表示尚未核定
  approvedAt     DateTime? @map("approved_at")
  approvedById   String?   @map("approved_by_id")
  createdAt      DateTime  @default(now()) @map("created_at")
  createdById    String    @map("created_by_id")
  deletedAt      DateTime? @map("deleted_at")
  deletedById    String?   @map("deleted_by_id")

  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy  User        @relation("PccesImportCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  approvedBy User?       @relation("PccesImportApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  attachment Attachment? @relation(fields: [attachmentId], references: [id], onDelete: SetNull)
  items      PccesItem[]
  itemChanges PccesItemChange[]

  @@unique([projectId, version])
  @@index([projectId])
  @@index([projectId, approvedAt])
  @@index([createdAt(sort: Desc)])
  @@map("pcces_imports")
}

model PccesItem {
  id             String    @id @default(cuid())
  importId       String    @map("import_id")
  itemKey        Int       @map("item_key")
  parentItemKey  Int?      @map("parent_item_key")
  itemNo         String    @map("item_no")
  itemKind       String    @map("item_kind") // XML PayItem kind（mainItem、general、formula、variablePrice 等）；是否可填量由 API／前端依 kind 決定
  refCode        String    @map("ref_code")
  description    String    @map("description") @db.Text
  unit           String    @map("unit")
  quantity       Decimal   @map("quantity") @db.Decimal(18, 4)
  unitPrice      Decimal   @map("unit_price") @db.Decimal(18, 4)
  amountImported Decimal?  @map("amount_imported") @db.Decimal(18, 4)
  remark         String    @default("") @map("remark") @db.Text
  percent        Decimal?  @map("percent") @db.Decimal(18, 4)
  path           String    @map("path") @db.Text
  depth          Int       @map("depth")
  deletedAt      DateTime? @map("deleted_at")
  deletedById    String?   @map("deleted_by_id")

  import PccesImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  dailyLogWorkItems ConstructionDailyLogWorkItem[]
  constructionValuationLines ConstructionValuationLine[]
  excelChanges PccesItemChange[]

  @@unique([importId, itemKey])
  @@index([importId])
  @@index([importId, itemKind])
  @@map("pcces_items")
}

/// PCCES 施工項目變更紀錄（Excel 確認匯入後寫入；與該版 import／工項關聯）
model PccesItemChange {
  id               String    @id @default(cuid())
  importId         String    @map("import_id")
  pccesItemId      String    @map("pcces_item_id")
  /// auto_matched | manually_placed
  kind             String    @map("kind")
  excelItemNo      String?   @map("excel_item_no") @db.VarChar(512)
  excelDescription String?   @map("excel_description") @db.Text
  excelUnit        String?   @map("excel_unit") @db.VarChar(512)
  excelQty         String?   @map("excel_qty") @db.VarChar(128)
  excelUnitPrice   String?   @map("excel_unit_price") @db.VarChar(128)
  excelRemark      String?   @map("excel_remark") @db.Text
  prevQuantity     String?   @map("prev_quantity") @db.VarChar(128)
  prevUnitPrice    String?   @map("prev_unit_price") @db.VarChar(128)
  newQuantity      String?   @map("new_quantity") @db.VarChar(128)
  newUnitPrice     String?   @map("new_unit_price") @db.VarChar(128)
  /// manually_placed：使用者指定之父層 itemKey
  parentItemKey    Int?      @map("parent_item_key")
  createdAt        DateTime  @default(now()) @map("created_at")
  createdById      String    @map("created_by_id")
  deletedAt        DateTime? @map("deleted_at")
  deletedById      String?   @map("deleted_by_id")

  import    PccesImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  pccesItem PccesItem   @relation(fields: [pccesItemId], references: [id], onDelete: Cascade)
  createdBy User      @relation(fields: [createdById], references: [id], onDelete: Restrict)

  @@index([importId])
  @@index([pccesItemId])
  @@map("pcces_item_changes")
}

/// 公共工程施工日誌主檔（依附表四欄位；軟刪除）
model ConstructionDailyLog {
  id     String @id @default(cuid())
  /// 專案識別
  projectId String @map("project_id")

  /// 表頭
  reportNo   String?   @map("report_no")
  weatherAm  String?   @map("weather_am")
  weatherPm  String?   @map("weather_pm")
  logDate    DateTime  @map("log_date") @db.Date

  /// 工程基本資料（表上快照；可與專案主檔不同步）
  projectName         String    @map("project_name")
  contractorName      String    @map("contractor_name")
  approvedDurationDays Int?     @map("approved_duration_days")
  accumulatedDays     Int?      @map("accumulated_days")
  remainingDays       Int?      @map("remaining_days")
  extendedDays        Int?      @map("extended_days")
  startDate           DateTime? @map("start_date") @db.Date
  completionDate      DateTime? @map("completion_date") @db.Date
  /// 實際進度（%）人工填寫；預定進度由 API 依開工日＋核定工期計算回傳
  actualProgress      Decimal?  @map("actual_progress") @db.Decimal(6, 2)

  /// 營造業專業工程特定施工項目
  specialItemA String @default("") @map("special_item_a") @db.Text
  specialItemB String @default("") @map("special_item_b") @db.Text

  /// 技術士
  hasTechnician Boolean @default(false) @map("has_technician")

  /// 職安衛
  preWorkEducation   String @default("no") @map("pre_work_education") // yes | no
  newWorkerInsurance String @default("no_new") @map("new_worker_insurance") // yes | no | no_new
  ppeCheck           String @default("no") @map("ppe_check") // yes | no
  otherSafetyNotes   String @default("") @map("other_safety_notes") @db.Text

  /// 備查
  sampleTestRecord   String @default("") @map("sample_test_record") @db.Text
  subcontractorNotice String @default("") @map("subcontractor_notice") @db.Text
  importantNotes     String @default("") @map("important_notes") @db.Text

  /// 簽章
  siteManagerSigned Boolean @default(false) @map("site_manager_signed")

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by_id")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("ConstructionDailyLogCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)

  workItems       ConstructionDailyLogWorkItem[]
  materials       ConstructionDailyLogMaterial[]
  personnelEquipmentRows ConstructionDailyLogPersonnelEquipment[]

  @@index([projectId])
  @@index([projectId, logDate(sort: Desc)])
  @@map("construction_daily_logs")
}

/// 施工日誌（一）施工項目
model ConstructionDailyLogWorkItem {
  id           String  @id @default(cuid())
  logId        String  @map("log_id")
  sortOrder    Int     @default(0) @map("sort_order")
  /// 綁定 PCCES general 列時供累計聚合（§4.1）；手填列為 null
  pccesItemId  String? @map("pcces_item_id")
  workItemName String  @map("work_item_name")
  unit         String
  contractQty  Decimal @map("contract_qty") @db.Decimal(18, 4)
  /// 綁定 PCCES 時之單價快照；換版後仍以儲存值為準
  unitPrice    Decimal? @map("unit_price") @db.Decimal(18, 4)
  dailyQty     Decimal @map("daily_qty") @db.Decimal(18, 4)
  accumulatedQty Decimal @map("accumulated_qty") @db.Decimal(18, 4)
  remark       String  @default("")

  log       ConstructionDailyLog @relation(fields: [logId], references: [id], onDelete: Cascade)
  pccesItem PccesItem?           @relation(fields: [pccesItemId], references: [id], onDelete: SetNull)

  @@index([logId])
  @@index([pccesItemId])
  @@map("construction_daily_log_work_items")
}

/// 施工日誌（二）材料
model ConstructionDailyLogMaterial {
  id             String  @id @default(cuid())
  logId          String  @map("log_id")
  sortOrder      Int     @default(0) @map("sort_order")
  materialName   String  @map("material_name")
  unit           String
  contractQty    Decimal @map("contract_qty") @db.Decimal(18, 4)
  dailyUsedQty   Decimal @map("daily_used_qty") @db.Decimal(18, 4)
  accumulatedQty Decimal @map("accumulated_qty") @db.Decimal(18, 4)
  remark         String  @default("")

  log ConstructionDailyLog @relation(fields: [logId], references: [id], onDelete: Cascade)

  @@index([logId])
  @@map("construction_daily_log_materials")
}

/// 施工日誌（三）人員及機具（一列可同時填工別／人數與機具）
model ConstructionDailyLogPersonnelEquipment {
  id                      String  @id @default(cuid())
  logId                   String  @map("log_id")
  sortOrder               Int     @default(0) @map("sort_order")
  workType                String  @default("") @map("work_type")
  dailyWorkers            Int     @default(0) @map("daily_workers")
  accumulatedWorkers      Int     @default(0) @map("accumulated_workers")
  equipmentName           String  @default("") @map("equipment_name")
  dailyEquipmentQty       Decimal @default(0) @map("daily_equipment_qty") @db.Decimal(18, 4)
  accumulatedEquipmentQty Decimal @default(0) @map("accumulated_equipment_qty") @db.Decimal(18, 4)

  log ConstructionDailyLog @relation(fields: [logId], references: [id], onDelete: Cascade)

  @@index([logId])
  @@map("construction_daily_log_personnel_equipment")
}

/// 專案估驗計價主檔（每次估驗一筆；明細為快照，可綁定 PCCES general 工項）
model ConstructionValuation {
  id     String @id @default(cuid())
  /// 專案識別
  projectId String @map("project_id")

  title         String?   @map("title")
  valuationDate DateTime? @map("valuation_date") @db.Date
  headerRemark  String    @default("") @map("header_remark") @db.Text

  createdById String   @map("created_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by_id")

  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User    @relation("ConstructionValuationCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  lines     ConstructionValuationLine[]

  @@index([projectId])
  @@index([projectId, valuationDate(sort: Desc)])
  @@map("construction_valuations")
}

model ConstructionValuationLine {
  id          String @id @default(cuid())
  valuationId String @map("valuation_id")
  sortOrder   Int    @default(0) @map("sort_order")
  /// 綁定最新核定版 PCCES general 時供跨次估驗加總上限；純手填列為 null
  pccesItemId String? @map("pcces_item_id")

  itemNo      String  @map("item_no")
  description String  @map("description") @db.Text
  unit        String
  /// （一）契約數量
  contractQty Decimal @map("contract_qty") @db.Decimal(18, 4)
  /// 變更後核定數量（有則以此為上限，否則用契約數量）
  approvedQtyAfterChange Decimal? @map("approved_qty_after_change") @db.Decimal(18, 4)
  /// （三）單價
  unitPrice Decimal @map("unit_price") @db.Decimal(18, 4)
  /// （四）本次估驗數量（手填）
  currentPeriodQty Decimal @map("current_period_qty") @db.Decimal(18, 4)

  remark String @default("") @map("remark") @db.Text

  valuation   ConstructionValuation @relation(fields: [valuationId], references: [id], onDelete: Cascade)
  pccesItem   PccesItem?            @relation(fields: [pccesItemId], references: [id], onDelete: SetNull)

  @@index([valuationId])
  @@index([pccesItemId])
  @@map("construction_valuation_lines")
}

// ---------- 氣象／災防警報紀錄（混合：即時顯示＋寫入保留查詢）----------
// 即時用：同類型同專案一筆，lastSeenAt 逾 30 分鐘不顯示
model AlertRecord {
  id          String    @id @default(cuid())
  projectId   String?   @map("project_id")   // 可選，未填則為全站
  alertType   String    @map("alert_type")  // 地震|豪雨|高溫|颱風|空污|其他
  level       String    @map("level")       // alarm|attention|normal
  title       String    @map("title")
  value       String    @map("value")      // 顯示用摘要
  description String?   @map("description")
  startTime   DateTime? @map("start_time")
  endTime     DateTime? @map("end_time")
  source      String    @default("cwa") @map("source")  // cwa|mock
  lastSeenAt  DateTime  @map("last_seen_at")  // 最後一次見到此警報時間，逾 30 分鐘則不顯示
  createdAt   DateTime  @default(now()) @map("created_at")

  project Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  @@unique([alertType, projectId])
  @@index([projectId])
  @@index([lastSeenAt])
  @@map("alert_records")
}

// 歷史用：每次寫入即時時一併 insert 一筆，供歷史列表查詢
model AlertHistoryRecord {
  id          String    @id @default(cuid())
  projectId   String?   @map("project_id")
  alertType   String    @map("alert_type")
  level       String    @map("level")
  title       String    @map("title")
  value       String    @map("value")
  description String?   @map("description")
  startTime   DateTime? @map("start_time")
  endTime     DateTime? @map("end_time")
  source      String    @default("cwa") @map("source")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([projectId])
  @@index([createdAt])
  @@index([alertType])
  @@map("alert_history_records")
}

// ---------- 相簿（專案內照片管理：圖庫／相簿）----------
model PhotoAlbum {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  name      String   @map("name")
  createdAt DateTime @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  deletedById String? @map("deleted_by_id")

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  albumPhotos AlbumPhoto[]
}

model AlbumPhoto {
  albumId      String @map("album_id")
  attachmentId String @map("attachment_id")

  album      PhotoAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  attachment Attachment @relation(fields: [attachmentId], references: [id], onDelete: Cascade)

  @@id([albumId, attachmentId])
  @@map("album_photos")
}

// ---------- 工期調整（專案內展延／停工申請與核定）----------
model ProjectScheduleAdjustment {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  applyDate    DateTime @map("apply_date")   // 申請日期
  type         String   @map("type")         // extension | suspension | other
  applyDays    Int      @map("apply_days")   // 申請天數
  approvedDays Int      @map("approved_days") // 核定天數
  status       String   @map("status")       // pending | approved | rejected
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  deletedById  String?   @map("deleted_by_id")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_schedule_adjustments")
}

// ---------- 專案成員（使用者－專案－角色）----------
enum ProjectRole {
  project_admin  // 專案管理員
  member         // 一般成員
  viewer         // 唯讀
}

model ProjectMember {
  id        String     @id @default(cuid())
  projectId String     @map("project_id")
  userId    String     @map("user_id")
  role      ProjectRole @default(member)
  status    String     @default("active") @map("status") // active | suspended（停用後無法存取專案）
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  deletedAt DateTime?  @map("deleted_at")
  deletedById String?  @map("deleted_by_id")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, userId])
  @@map("project_members")
}

// ---------- 租戶層：成員權限範本（加入專案時複製至 project_member_permissions）----------
model TenantPermissionTemplate {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  module    String   @map("module") // 如 project.overview、construction.defect
  canCreate Boolean  @default(false) @map("can_create")
  canRead   Boolean  @default(false) @map("can_read")
  canUpdate Boolean  @default(false) @map("can_update")
  canDelete Boolean  @default(false) @map("can_delete")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, module])
  @@index([tenantId, userId])
  @@map("tenant_permission_templates")
}

// ---------- 專案層：成員模組權限（可覆寫範本）----------
model ProjectMemberPermission {
  id        String   @id @default(cuid())
  projectId String   @map("project_id")
  userId    String   @map("user_id")
  module    String   @map("module")
  canCreate Boolean  @default(false) @map("can_create")
  canRead   Boolean  @default(false) @map("can_read")
  canUpdate Boolean  @default(false) @map("can_update")
  canDelete Boolean  @default(false) @map("can_delete")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId, module])
  @@index([projectId, userId])
  @@map("project_member_permissions")
}

// ---------- 攝影機（專案級，go2rtc 推流；一機一 Token）----------
model Camera {
  id               String    @id @default(cuid())
  projectId        String    @map("project_id")
  tenantId         String?   @map("tenant_id")
  name             String    @map("name")
  streamToken      String    @map("stream_token")   // UUID v4，= mediamtx path 名
  connectionMode   String    @default("go2rtc") @map("connection_mode") // go2rtc | fixed_ip（未來）
  sourceUrlEnc     String?   @map("source_url_enc")        // 設備 RTSP URL 加密儲存（選填，供 go2rtc 設定範例）
  status           String    @default("active") @map("status") // active | disabled
  lastStreamAt     DateTime? @map("last_stream_at")       // 最後一次偵測到推流成功的時間；null = 尚未設定
  connectionStatusOverride String? @map("connection_status_override") // 'offline' = 手動標示為離線（不影響實際串流）
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")
  deletedById      String?   @map("deleted_by_id")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([tenantId])
  @@index([streamToken])
  @@map("cameras")
}

// ---------- 缺失改善（手機／現場：問題說明、發現人、優先度、樓層、位置、狀態、照片）----------
model DefectImprovement {
  id           String   @id @default(cuid())
  projectId    String   @map("project_id")
  description  String   @map("description")   // 問題說明
  discoveredBy String   @map("discovered_by") // 發現人（姓名）
  priority     String   @default("medium") @map("priority")  // low | medium | high
  floor        String?  @map("floor")         // 樓層
  location     String?  @map("location")      // 位置
  status       String   @default("in_progress") @map("status") // in_progress | completed
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  deletedById  String?   @map("deleted_by_id")

  project  Project                 @relation(fields: [projectId], references: [id], onDelete: Cascade)
  records  DefectExecutionRecord[]

  @@index([projectId])
  @@index([projectId, status])
  @@map("defect_improvements")
}

// ---------- 缺失改善執行紀錄（歷程：內容、紀錄人、時間；照片用 Attachment businessId=id, category=defect_record）----------
model DefectExecutionRecord {
  id          String   @id @default(cuid())
  defectId    String   @map("defect_id")
  content     String   @map("content")       // 執行紀錄內容
  recordedById String? @map("recorded_by_id")
  createdAt   DateTime @default(now()) @map("created_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedById String?   @map("deleted_by_id")

  defect   DefectImprovement @relation(fields: [defectId], references: [id], onDelete: Cascade)
  recordedBy User?           @relation(fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([defectId])
  @@map("defect_execution_records")
}

// ---------- 報修單（手機／現場：客戶、聯絡、報修內容、戶別、問題類別、日期、照片與附件）----------
model RepairRequest {
  id               String    @id @default(cuid())
  projectId        String    @map("project_id")
  customerName     String    @map("customer_name")
  contactPhone     String    @map("contact_phone")
  repairContent    String    @map("repair_content")
  unitLabel        String?   @map("unit_label")
  remarks          String?   @map("remarks")
  problemCategory  String    @map("problem_category")
  isSecondRepair   Boolean   @default(false) @map("is_second_repair")
  deliveryDate     DateTime? @map("delivery_date")
  repairDate       DateTime? @map("repair_date")
  status           String    @default("in_progress") @map("status") // in_progress | completed
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")
  deletedById      String?   @map("deleted_by_id")

  project Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  records RepairExecutionRecord[]

  @@index([projectId])
  @@index([projectId, status])
  @@map("repair_requests")
}

// ---------- 報修紀錄（處理歷程；照片用 Attachment businessId=id, category=repair_record）----------
model RepairExecutionRecord {
  id             String   @id @default(cuid())
  repairId       String   @map("repair_id")
  content        String   @map("content")
  recordedById   String?  @map("recorded_by_id")
  createdAt      DateTime @default(now()) @map("created_at")
  deletedAt      DateTime? @map("deleted_at")
  deletedById    String?   @map("deleted_by_id")

  repair     RepairRequest @relation(fields: [repairId], references: [id], onDelete: Cascade)
  recordedBy User?        @relation(fields: [recordedById], references: [id], onDelete: SetNull)

  @@index([repairId])
  @@map("repair_execution_records")
}
